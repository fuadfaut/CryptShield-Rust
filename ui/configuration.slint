import { ProtectionSwitch } from "components.slint";

component ResolverOption inherits Rectangle {
    in property <string> resolver-id;
    in property <string> name;
    in property <string> description;
    in property <bool> selected;
    callback chosen(string);

    height: 52px;
    border-radius: 10px;
    border-width: 1px;
    border-color: root.selected ? #89b4fa : #313244;
    background: root.selected ? #313244 : #1e1e2e;
    animate background, border-color { duration: 140ms; easing: ease; }

    Text {
        x: 14px;
        y: 6px;
        width: parent.width - 106px;
        text: root.name;
        color: #ffffff;
        font-size: 14px;
        font-weight: 800;
    }

    Text {
        x: 14px;
        y: 28px;
        width: parent.width - 106px;
        text: root.description;
        color: #a6adc8;
        font-size: 11px;
    }

    Rectangle {
        x: parent.width - 74px;
        y: 14px;
        width: 58px;
        height: 24px;
        border-radius: 12px;
        background: root.selected ? #89b4fa : #313244;

        Text {
            text: root.selected ? "Active" : "Select";
            color: root.selected ? #111827 : #cdd6f4;
            font-size: 11px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            root.chosen(root.resolver-id);
        }
    }
}

component ToggleRow inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in property <bool> checked;
    callback toggled(bool);

    height: 56px;
    background: transparent;

    Text {
        x: 0;
        y: 6px;
        width: parent.width - 132px;
        text: root.label;
        color: #ffffff;
        font-size: 15px;
        font-weight: 800;
    }

    Text {
        x: 0;
        y: 30px;
        width: parent.width - 132px;
        text: root.description;
        color: #a6adc8;
        font-size: 12px;
    }

    ProtectionSwitch {
        x: parent.width - 96px;
        y: 4px;
        checked: root.checked;
        toggled => {
            root.toggled(!root.checked);
        }
    }
}

export component ConfigurationView inherits Rectangle {
    in property <string> current-resolver-id;
    in property <string> current-resolver-name;
    in property <string> config-status;
    in property <bool> cache-enabled;
    in property <bool> dnssec-enabled;
    in property <bool> autostart-enabled;
    callback select-resolver(string);
    callback set-cache-enabled(bool);
    callback set-dnssec-enabled(bool);
    callback set-autostart-enabled(bool);

    border-radius: 24px;
    border-width: 1px;
    border-color: #313244;
    background: #27273a;

    Text {
        x: 32px;
        y: 24px;
        text: "Configuration";
        color: #ffffff;
        font-size: 22px;
        font-weight: 800;
    }

    Text {
        x: 32px;
        y: 60px;
        width: parent.width - 64px;
        text: "Current resolver: " + root.current-resolver-name + "  |  config: " + root.config-status;
        color: #a6adc8;
        font-size: 14px;
    }

    ResolverOption {
        x: 32px;
        y: 100px;
        width: (parent.width - 88px) / 2;
        resolver-id: "default";
        name: "Default";
        description: "Load-balanced dnscrypt-proxy resolver set.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 56px + (parent.width - 88px) / 2;
        y: 100px;
        width: (parent.width - 88px) / 2;
        resolver-id: "cloudflare";
        name: "Cloudflare";
        description: "Fast general-purpose DNSCrypt resolver.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 32px;
        y: 160px;
        width: (parent.width - 88px) / 2;
        resolver-id: "google";
        name: "Google";
        description: "High-availability public DNS resolver.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 56px + (parent.width - 88px) / 2;
        y: 160px;
        width: (parent.width - 88px) / 2;
        resolver-id: "quad9";
        name: "Quad9";
        description: "Security resolver with threat blocking.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 32px;
        y: 220px;
        width: (parent.width - 88px) / 2;
        resolver-id: "adguard";
        name: "AdGuard DNS";
        description: "Privacy resolver with ad filtering.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 56px + (parent.width - 88px) / 2;
        y: 220px;
        width: (parent.width - 88px) / 2;
        resolver-id: "nextdns";
        name: "NextDNS";
        description: "Configurable privacy-focused resolver.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 32px;
        y: 280px;
        width: (parent.width - 88px) / 2;
        resolver-id: "cisco";
        name: "Cisco";
        description: "Security-oriented public resolver.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 56px + (parent.width - 88px) / 2;
        y: 280px;
        width: (parent.width - 88px) / 2;
        resolver-id: "mullvad";
        name: "Mullvad";
        description: "Privacy-first DoH resolver.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 32px;
        y: 340px;
        width: (parent.width - 88px) / 2;
        resolver-id: "cleanbrowsing";
        name: "CleanBrowsing";
        description: "Family/adult-content filtering.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    ResolverOption {
        x: 56px + (parent.width - 88px) / 2;
        y: 340px;
        width: (parent.width - 88px) / 2;
        resolver-id: "tiarapp";
        name: "Tiarap DNS";
        description: "Community DNS-over-HTTPS resolver.";
        selected: root.current-resolver-id == self.resolver-id;
        chosen(id) => { root.select-resolver(id); }
    }

    Rectangle {
        x: 32px;
        y: 412px;
        width: parent.width - 64px;
        height: 1px;
        background: #313244;
    }

    ToggleRow {
        x: 32px;
        y: 432px;
        width: parent.width - 64px;
        label: "DNS cache";
        description: "Keep repeated lookups fast when supported by the daemon config.";
        checked: root.cache-enabled;
        toggled(value) => { root.set-cache-enabled(value); }
    }

    ToggleRow {
        x: 32px;
        y: 492px;
        width: parent.width - 64px;
        label: "Require DNSSEC";
        description: "Prefer resolvers that validate signed DNS responses.";
        checked: root.dnssec-enabled;
        toggled(value) => { root.set-dnssec-enabled(value); }
    }

    ToggleRow {
        x: 32px;
        y: 552px;
        width: parent.width - 64px;
        label: "Autostart";
        description: "Remember preference locally until system integration is added.";
        checked: root.autostart-enabled;
        toggled(value) => { root.set-autostart-enabled(value); }
    }
}

import { MetricCard, ProtectionSwitch } from "components.slint";

export component DashboardView inherits Rectangle {
    in property <bool> protected;
    in property <bool> is-applying;
    in property <string> current-resolver-name;
    callback toggle-protection();

    property <length> top-card-height: 320px;
    property <length> gap: 24px;
    property <length> live-width: root.width / 3;
    property <length> protection-width: root.width - root.live-width - root.gap;
    property <length> metric-width: (root.width - 48px) / 3;

    background: transparent;

    Rectangle {
        x: 0;
        y: 0;
        width: root.protection-width;
        height: root.top-card-height;
        border-radius: 24px;
        border-width: 1px;
        border-color: #313244;
        background: #27273a;

        Rectangle {
            x: (parent.width - 112px) / 2;
            y: 34px;
            width: 112px;
            height: 112px;
            border-radius: 56px;
            background: root.protected ? #a6e3a133 : #f38ba833;
            animate background { duration: 260ms; easing: ease; }

            Image {
                x: 28px;
                y: 28px;
                width: 56px;
                height: 56px;
                source: root.protected ? @image-url("../assets/logo.svg") : @image-url("../assets/logo-off.svg");
            }
        }

        Text {
            x: 0;
            y: 174px;
            width: parent.width;
            text: root.is-applying ? "Applying" : root.protected ? "Protected" : "Unprotected";
            color: root.is-applying ? #f9e2af : root.protected ? #a6e3a1 : #ffffff;
            font-size: 30px;
            font-weight: 900;
            horizontal-alignment: center;
            animate color { duration: 200ms; easing: ease; }
        }

        Text {
            x: 24px;
            y: 224px;
            width: parent.width - 48px;
            text: root.is-applying ? "Preparing privileged action preview..." : root.protected ? "Traffic encrypted via " + root.current-resolver-name + "." : "System DNS is bypassing encryption.";
            color: #a6adc8;
            font-size: 14px;
            horizontal-alignment: center;
        }

        ProtectionSwitch {
            x: (parent.width - 96px) / 2;
            y: 262px;
            checked: root.is-applying ? !root.protected : root.protected;
            toggled => {
                root.toggle-protection();
            }
        }
    }

    Rectangle {
        x: root.protection-width + root.gap;
        y: 0;
        width: root.live-width;
        height: root.top-card-height;
        border-radius: 24px;
        border-width: 1px;
        border-color: #313244;
        background: #27273a;

        Image {
            x: 24px;
            y: 23px;
            width: 16px;
            height: 16px;
            source: @image-url("../assets/icon-pulse.svg");
        }

        Text {
            x: 48px;
            y: 22px;
            text: "LIVE TRAFFIC";
            color: #a6adc8;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 1px;
        }

        Text {
            x: 24px;
            y: 92px;
            text: "Total Queries";
            color: #cdd6f4;
            font-size: 14px;
        }

        Text {
            x: parent.width - 48px;
            y: 92px;
            width: 24px;
            text: "0";
            color: #ffffff;
            font-size: 14px;
            horizontal-alignment: right;
        }

        Rectangle {
            x: 24px;
            y: 122px;
            width: parent.width - 48px;
            height: 8px;
            border-radius: 4px;
            background: #313244;

            Rectangle {
                width: parent.width;
                height: parent.height;
                border-radius: 4px;
                background: #60a5fa80;
            }
        }

        Text {
            x: 24px;
            y: 154px;
            text: "Blocked (Ad/Malware)";
            color: #cdd6f4;
            font-size: 14px;
        }

        Text {
            x: parent.width - 48px;
            y: 154px;
            width: 24px;
            text: "0";
            color: #f38ba8;
            font-size: 14px;
            horizontal-alignment: right;
        }

        Rectangle {
            x: 24px;
            y: 184px;
            width: parent.width - 48px;
            height: 8px;
            border-radius: 4px;
            background: #313244;
        }

        Rectangle {
            x: 24px;
            y: 226px;
            width: parent.width - 48px;
            height: 1px;
            background: #313244;
        }

        Text {
            x: 24px;
            y: 248px;
            width: parent.width - 48px;
            text: root.is-applying ? "Applying requested state..." : root.protected ? "Monitoring active queries..." : "Waiting for service to start...";
            color: root.is-applying ? #f9e2af : root.protected ? #a6e3a1 : #6c7086;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            animate color { duration: 200ms; easing: ease; }
        }
    }

    MetricCard {
        x: 0;
        y: root.top-card-height + root.gap;
        width: root.metric-width;
        icon: @image-url("../assets/icon-globe.svg");
        icon-background: #3b82f633;
        label: "Active Resolver";
        value: root.protected ? root.current-resolver-name : "None";
    }

    MetricCard {
        x: root.metric-width + root.gap;
        y: root.top-card-height + root.gap;
        width: root.metric-width;
        icon: @image-url("../assets/icon-chart.svg");
        icon-background: #a855f733;
        label: "Avg. Latency";
        value: root.protected ? "12 ms" : "-- ms";
    }

    MetricCard {
        x: (root.metric-width + root.gap) * 2;
        y: root.top-card-height + root.gap;
        width: root.metric-width;
        icon: @image-url("../assets/icon-clock.svg");
        icon-background: #10b98133;
        label: "Uptime";
        value: root.protected ? "00:00:08" : "00:00:00";
    }
}
